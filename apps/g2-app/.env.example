# Base URL of the deployed translator-api Cloudflare Worker.
# Copy this file to `.env.local` and adjust. Never put API keys or other
# secrets here: everything in VITE_* is embedded into the public bundle.
#
# Local development (wrangler dev):
#   VITE_TRANSLATION_API_URL=http://localhost:8787
# Deployed Worker:
#   VITE_TRANSLATION_API_URL=https://turntranslate-api.YOUR_SUBDOMAIN.workers.dev
VITE_TRANSLATION_API_URL=http://localhost:8787
