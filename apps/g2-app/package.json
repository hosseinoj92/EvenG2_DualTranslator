{
  "name": "@turntranslate/g2-app",
  "version": "0.1.0",
  "private": true,
  "description": "Even Hub app for the G2 glasses: bidirectional conversation translator.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "simulate": "evenhub-simulator http://localhost:5173",
    "pack": "npm run build && evenhub pack app.json dist -o turntranslate.ehpk"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.12",
    "@evenrealities/pretext": "^0.1.4",
    "@turntranslate/shared": "*"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.8.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "vitest": "^3.0.5"
  }
}
