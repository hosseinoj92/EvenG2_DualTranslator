diff --git a/apps/g2-app/test/renderQueue.test.ts b/apps/g2-app/test/renderQueue.test.ts
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/apps/g2-app/test/renderQueue.test.ts
@@ -0,0 +1,66 @@
+import { afterEach, describe, expect, it, vi } from 'vitest';
+import { RenderQueue } from '../src/even/renderQueue';
+
+interface Deferred {
+  promise: Promise<void>;
+  resolve: () => void;
+}
+
+function deferred(): Deferred {
+  let resolve!: () => void;
+  const promise = new Promise<void>((done) => {
+    resolve = done;
+  });
+  return { promise, resolve };
+}
+
+afterEach(() => {
+  vi.useRealTimers();
+});
+
+describe('RenderQueue', () => {
+  it('skips stale container writes when a newer display model is pending', async () => {
+    vi.useFakeTimers();
+
+    const firstWrite = deferred();
+    const writes: Array<[number, string]> = [];
+
+    const queue = new RenderQueue(
+      {
+        write: async (containerId, content) => {
+          writes.push([containerId, content]);
+          if (writes.length === 1) {
+            await firstWrite.promise;
+          }
+        },
+      },
+      10,
+    );
+
+    queue.enqueue(1, 'old header');
+    queue.enqueue(2, 'old partial translation');
+    queue.enqueue(3, 'old footer');
+
+    await vi.advanceTimersByTimeAsync(10);
+    expect(writes).toEqual([[1, 'old header']]);
+
+    // A completed final result arrives while the first old BLE write is still
+    // unresolved. The remaining old body/footer must never be sent.
+    queue.enqueue(1, 'final header');
+    queue.enqueue(2, 'final completed translation');
+    queue.enqueue(3, 'final footer');
+    await vi.advanceTimersByTimeAsync(10);
+
+    firstWrite.resolve();
+    await queue.settle();
+
+    expect(writes).toEqual([
+      [1, 'old header'],
+      [1, 'final header'],
+      [2, 'final completed translation'],
+      [3, 'final footer'],
+    ]);
+
+    queue.dispose();
+  });
+});
